{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://proyectos-cjdg-production.up.railway.app/api/:path*"
    },
    {
      "source": "/static/:path*",
      "destination": "https://proyectos-cjdg-production.up.railway.app/static/:path*"
    },
    {
      "source": "/((?!api|static).*)",
      "destination": "/index.html"
    }
  ]
}
