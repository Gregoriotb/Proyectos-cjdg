*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/

# -------- Node / Frontend --------
node_modules/
frontend/dist/
.vite/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -------- OS / Editor --------
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# -------- Archivos temporales backend --------
backend/tmp_*
*.sqlite
*.db
