# ============================================================
# Proyectos CJDG — Backend env vars (EJEMPLO)
# Copiar a .env y rellenar. NUNCA commitear .env.
# ============================================================

# -------- Core --------
ENVIRONMENT=development
SECRET_KEY=change_this_in_production_very_long_random_string
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# -------- OAuth Google (SC-AUTH-OAUTH) --------
# Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client IDs
# NOTA: OAuth solo opera contra Railway/Vercel (no hay orígenes localhost registrados).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# URL absoluta del callback del backend (debe coincidir EXACTO con el registrado en Google Cloud)
GOOGLE_REDIRECT_URI=https://proyectos-cjdg-production.up.railway.app/api/v1/auth/google/callback
# URL del frontend al que se redirige tras login exitoso (con el JWT)
FRONTEND_URL=https://www.proyectoscjdg.com
